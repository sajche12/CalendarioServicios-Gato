# ==============================================================================
# TOURFLOW - CONFIGURACIÓN DE VARIABLES DE ENTORNO (.env.local)
# ==============================================================================
# Copia este archivo como '.env.local' y completa con tus credenciales reales.
# Las variables marcadas con [OBLIGATORIO] son indispensables para iniciar.

# ------------------------------------------------------------------------------
# 1. Supabase (Base de datos y Storage) - [OBLIGATORIO]
# ------------------------------------------------------------------------------
# La URL de tu proyecto de Supabase (ej. https://abcdefgh.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=tu-supabase-project-url

# La clave anónima pública de Supabase (se encuentra en Settings > API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-supabase-anon-key

# ------------------------------------------------------------------------------
# 2. Seguridad de Acceso - [OPCIONAL]
# ------------------------------------------------------------------------------
# Código numérico o palabra clave para autenticar al administrador.
APP_PASSCODE=codigo-no-disponible-por-el-momento

# ------------------------------------------------------------------------------
# 3. Notificaciones Push Web - [OPCIONAL]
# ------------------------------------------------------------------------------
# Necesarias para el envío de notificaciones push de los recordatorios.
# Puedes generarlas usando 'npx web-push generate-vapid-keys'
NEXT_PUBLIC_VAPID_PUBLIC_KEY=tu-clave-publica-vapid
VAPID_PRIVATE_KEY=tu-clave-privada-vapid

# ------------------------------------------------------------------------------
# 4. Tareas Programadas (Cron) - [OPCIONAL]
# ------------------------------------------------------------------------------
# Secreto para autorizar la ejecución del endpoint api/cron-reminders
CRON_SECRET=tu-secreto-de-cron-autorizacion
